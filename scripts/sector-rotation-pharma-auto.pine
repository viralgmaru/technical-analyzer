//@version=5
indicator("Sector Rotation - Pharma & Auto", overlay=false)

rsi_p = input(14, "RSI")
ma_s = input(20, "MA Short")
ma_l = input(200, "MA Long")
th = input.float(1.0, "Threshold")

ph_rg = input.int(1, "Pharma Reg")
au_rg = input.int(-1, "Auto Reg")

f_score(t, tf, r) =>
    cls = request.security(t, tf, close)
    vol = request.security(t, tf, volume)
    rsi = request.security(t, tf, ta.rsi(cls, rsi_p))
    sma_s = request.security(t, tf, ta.sma(cls, ma_s))
    sma_l = request.security(t, tf, ta.sma(cls, ma_l))
    
    gs = 0.0
    if rsi > 65
        gs += 4.0
    else if rsi > 55
        gs += 3.0
    else if rsi > 45
        gs += 2.0
    else if rsi < 35
        gs += 1.0
    if cls > sma_s and cls > sma_l
        gs += 3.0
    else if cls > sma_s
        gs += 2.0
    else if cls > sma_l
        gs += 1.0
    
    vs = 1.0
    rm = cls / sma_l
    if rm < 0.95
        vs = 9.0
    else if rm < 1.0
        vs = 7.0
    else if rm < 1.1
        vs = 5.0
    else if rm < 1.2
        vs = 3.0
    else
        vs = 1.0
    
    vm = request.security(t, tf, ta.sma(vol, 20))
    vr = vol / vm
    fs = vr > 1.2 ? 3.0 : vr > 1.0 ? 2.0 : 1.0
    
    rs = math.max(0.0, math.min(5.0 + r, 10.0))
    (0.35 * math.min(gs, 10.0)) + (0.35 * vs) + (0.20 * fs) + (0.10 * rs)

f_multi(t, r) =>
    d = f_score(t, "D", r)
    w = f_score(t, "W", r)
    (0.60 * d) + (0.40 * w)

ph_m = f_multi("NIFTY_PHARMA", ph_rg)
au_m = f_multi("NIFTY_AUTO", au_rg)

var h_ph = array.new<float>()
var h_au = array.new<float>()

if barstate.isnew
    array.push(h_ph, ph_m)
    if array.size(h_ph) > 20
        array.shift(h_ph)
    array.push(h_au, au_m)
    if array.size(h_au) > 20
        array.shift(h_au)

plot(ph_m, "Pharma", color.green, style=plot.style_columns)
plot(au_m, "Auto", color.red, style=plot.style_columns)

hline(7.0, "Attractive", color=color.gray, linestyle=hline.style_dotted)
hline(5.0, "Moderate", color=color.gray, linestyle=hline.style_dotted)

if barstate.isconfirmed
    if array.size(h_ph) > 0
        a = array.avg(h_ph)
        if ph_m - a > th
            alert("🟢 PH " + str.tostring(math.round(ph_m, 1)), alert.freq_once_per_bar)
        if ph_m - a < -th
            alert("🔴 PH " + str.tostring(math.round(ph_m, 1)), alert.freq_once_per_bar)
    if array.size(h_au) > 0
        a = array.avg(h_au)
        if au_m - a > th
            alert("🟢 AU " + str.tostring(math.round(au_m, 1)), alert.freq_once_per_bar)
        if au_m - a < -th
            alert("🔴 AU " + str.tostring(math.round(au_m, 1)), alert.freq_once_per_bar)
