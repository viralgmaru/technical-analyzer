//@version=5
indicator("Sector Rotation - Multi-Timeframe", overlay=false)

rsi_p = input(14, "RSI")
ma_s = input(20, "MA Short")
ma_l = input(200, "MA Long")
th = input.float(1.0, "Threshold")

it_en = input(true, "IT")
bk_en = input(true, "Bank")

it_rg = input.int(0, "IT Reg")
bk_rg = input.int(0, "Bank Reg")

f_score(t, tf, r) =>
    cls = request.security(t, tf, close)
    vol = request.security(t, tf, volume)
    rsi = request.security(t, tf, ta.rsi(cls, rsi_p))
    sma_s = request.security(t, tf, ta.sma(cls, ma_s))
    sma_l = request.security(t, tf, ta.sma(cls, ma_l))
    
    gs = 0.0
    if rsi > 65
        gs += 4.0
    else if rsi > 55
        gs += 3.0
    else if rsi > 45
        gs += 2.0
    else if rsi < 35
        gs += 1.0
    if cls > sma_s and cls > sma_l
        gs += 3.0
    else if cls > sma_s
        gs += 2.0
    else if cls > sma_l
        gs += 1.0
    
    vs = 1.0
    rm = cls / sma_l
    if rm < 0.95
        vs = 9.0
    else if rm < 1.0
        vs = 7.0
    else if rm < 1.1
        vs = 5.0
    else if rm < 1.2
        vs = 3.0
    else
        vs = 1.0
    
    vm = request.security(t, tf, ta.sma(vol, 20))
    vr = vol / vm
    obv = request.security(t, tf, ta.obv)
    obvm = request.security(t, tf, ta.sma(obv, 20))
    
    vs2 = 0.0
    if vr > 1.2
        vs2 = 3.0
    else if vr > 1.0
        vs2 = 2.0
    else if vr > 0.8
        vs2 = 1.0
    fs = math.min(vs2 + (obv > obvm ? 2.0 : 0.5), 10.0)
    
    rs = math.max(0.0, math.min(5.0 + r, 10.0))
    (0.35 * math.min(gs, 10.0)) + (0.35 * vs) + (0.20 * fs) + (0.10 * rs)

f_multi(t, r) =>
    d = f_score(t, "D", r)
    w = f_score(t, "W", r)
    (0.60 * d) + (0.40 * w)

it_m = it_en ? f_multi("NIFTY_IT", it_rg) : na
bk_m = bk_en ? f_multi("NIFTY_BANK", bk_rg) : na

var h_it = array.new<float>()
var h_bk = array.new<float>()

if barstate.isnew
    if it_en
        array.push(h_it, it_m)
        if array.size(h_it) > 20
            array.shift(h_it)
    if bk_en
        array.push(h_bk, bk_m)
        if array.size(h_bk) > 20
            array.shift(h_bk)

plot(it_m, "IT-Multi", color.blue, style=plot.style_columns)
plot(bk_m, "BK-Multi", color.orange, style=plot.style_columns)

hline(7.0, "Attractive", color=color.gray, linestyle=hline.style_dotted)
hline(5.0, "Moderate", color=color.gray, linestyle=hline.style_dotted)

if barstate.isconfirmed
    if it_en and array.size(h_it) > 0
        a = array.avg(h_it)
        if it_m - a > th
            alert("🟢 IT " + str.tostring(math.round(it_m, 1)), alert.freq_once_per_bar)
        if it_m - a < -th
            alert("🔴 IT " + str.tostring(math.round(it_m, 1)), alert.freq_once_per_bar)
    if bk_en and array.size(h_bk) > 0
        a = array.avg(h_bk)
        if bk_m - a > th
            alert("🟢 BK " + str.tostring(math.round(bk_m, 1)), alert.freq_once_per_bar)
        if bk_m - a < -th
            alert("🔴 BK " + str.tostring(math.round(bk_m, 1)), alert.freq_once_per_bar)
