//@version=5
indicator("Sector Rotation - Metals & FMCG", overlay=false)

rsi_p = input(14, "RSI")
ma_s = input(20, "MA Short")
ma_l = input(200, "MA Long")
th = input.float(1.0, "Threshold")

mt_rg = input.int(-1, "Metals Reg")
fg_rg = input.int(0, "FMCG Reg")

f_score(t, tf, r) =>
    cls = request.security(t, tf, close)
    vol = request.security(t, tf, volume)
    rsi = request.security(t, tf, ta.rsi(cls, rsi_p))
    sma_s = request.security(t, tf, ta.sma(cls, ma_s))
    sma_l = request.security(t, tf, ta.sma(cls, ma_l))
    
    gs = 0.0
    if rsi > 65
        gs += 4.0
    else if rsi > 55
        gs += 3.0
    else if rsi > 45
        gs += 2.0
    else if rsi < 35
        gs += 1.0
    if cls > sma_s and cls > sma_l
        gs += 3.0
    else if cls > sma_s
        gs += 2.0
    else if cls > sma_l
        gs += 1.0
    
    vs = 1.0
    rm = cls / sma_l
    if rm < 0.95
        vs = 9.0
    else if rm < 1.0
        vs = 7.0
    else if rm < 1.1
        vs = 5.0
    else if rm < 1.2
        vs = 3.0
    else
        vs = 1.0
    
    vm = request.security(t, tf, ta.sma(vol, 20))
    vr = vol / vm
    fs = vr > 1.2 ? 3.0 : vr > 1.0 ? 2.0 : 1.0
    
    rs = math.max(0.0, math.min(5.0 + r, 10.0))
    (0.35 * math.min(gs, 10.0)) + (0.35 * vs) + (0.20 * fs) + (0.10 * rs)

f_multi(t, r) =>
    d = f_score(t, "D", r)
    w = f_score(t, "W", r)
    (0.60 * d) + (0.40 * w)

mt_m = f_multi("NIFTY_METALS", mt_rg)
fg_m = f_multi("NIFTY_FMCG", fg_rg)

var h_mt = array.new<float>()
var h_fg = array.new<float>()

if barstate.isnew
    array.push(h_mt, mt_m)
    if array.size(h_mt) > 20
        array.shift(h_mt)
    array.push(h_fg, fg_m)
    if array.size(h_fg) > 20
        array.shift(h_fg)

plot(mt_m, "Metals", color.purple, style=plot.style_columns)
plot(fg_m, "FMCG", color.teal, style=plot.style_columns)

hline(7.0, "Attractive", color=color.gray, linestyle=hline.style_dotted)
hline(5.0, "Moderate", color=color.gray, linestyle=hline.style_dotted)

if barstate.isconfirmed
    if array.size(h_mt) > 0
        a = array.avg(h_mt)
        if mt_m - a > th
            alert("🟢 MT " + str.tostring(math.round(mt_m, 1)), alert.freq_once_per_bar)
        if mt_m - a < -th
            alert("🔴 MT " + str.tostring(math.round(mt_m, 1)), alert.freq_once_per_bar)
    if array.size(h_fg) > 0
        a = array.avg(h_fg)
        if fg_m - a > th
            alert("🟢 FG " + str.tostring(math.round(fg_m, 1)), alert.freq_once_per_bar)
        if fg_m - a < -th
            alert("🔴 FG " + str.tostring(math.round(fg_m, 1)), alert.freq_once_per_bar)
